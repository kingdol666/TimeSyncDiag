# ============================================
# TimeSyncDiag 环境变量示例
# 复制此文件为 .env 并根据环境修改
# ============================================
# cp .env.example .env
# ============================================

# ── 阿里云通义千问 API 密钥（用于 QwenVL Agent）──
DASHSCOPE_API_KEY=your_api_key_here

# ── 数据库配置 ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tsdb
DB_USER=user
DB_PASSWORD=123456

# ── MinIO 配置 ──
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=Minio@123456
MINIO_BUCKET_NAME=test-bucket
MINIO_SECURE=false

# ── Kafka 配置 ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SENSOR_TOPIC=sensor_data
KAFKA_DETECTION_TOPIC=detection_data

# ── API 配置 ──
API_HOST=0.0.0.0
API_PORT=8000

# ── LLM 配置 ──
QWEN_MODEL_NAME=qwen3-vl-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TEMPERATURE=1.0
QWEN_MAX_TOKENS=5000

# ── WebSocket ──
WS_HEARTBEAT_INTERVAL=30
