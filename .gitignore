# ============================================
# TimeSyncDiag 后端 - .gitignore
# ============================================

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# ── 虚拟环境 ──
.venv/
venv/
env/
.conda/

# ── 环境变量 ──
.env
.env.local
.env.*.local

# ── 本地配置文件（敏感信息） ──
config.yml

# ── 运行时状态文件 ──
backend/config/producer_state.json

# ── 数据文件 ──
backend/data/realtime/
backend/data/motouData/
backend/data/otherData/

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── 操作系统 ──
.DS_Store
Thumbs.db

# ── Jupyter ──
.ipynb_checkpoints/

# ── 日志 ──
*.log
pandasai.log

# Qdrant vector database (auto-generated)
backend/LLMAgent/KnowledgeDb/qdrant_db/

# Large files (use LFS or download from GitHub Releases)
cnn_image_classification/best_resnet_model.keras
cnn_image_classification/*.png
cnn_image_classification/.venv/
